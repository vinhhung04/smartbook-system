# Shared environment variables for docker-compose services
# Copy to .env before running Docker stack.

POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=inventory

DB_HOST=db
DB_PORT=5432
DB_USER=user
DB_PASSWORD=password
DB_NAME=inventory
AUTH_DB_NAME=auth_db
INVENTORY_DB_NAME=inventory_db
BORROW_DB_NAME=borrow_db

JWT_SECRET=smartbook_shared_jwt_secret

# Internal service-to-service key for WebSocket push events
INTERNAL_SERVICE_KEY=smartbook_internal_key

PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin

# Used by frontend in local runtime
VITE_API_BASE_URL=http://localhost:3000
VITE_AUTH_BASE_URL=http://localhost:3000
VITE_AI_BASE_URL=http://localhost:3000/ai
VITE_GATEWAY_BASE_URL=http://localhost:3000

# Ollama — mặc định llama3 (model text). llava là vision model, không phù hợp cho tóm tắt văn bản.
SUMMARY_MODEL=llama3
OLLAMA_HOST=http://ollama:11434

# ISBN metadata lookup — tắt WorldCat mặc định để lookup nhanh hơn
GOOGLE_BOOKS_API_BASE_URL=https://www.googleapis.com/books/v1/volumes
OPEN_LIBRARY_API_BASE_URL=https://openlibrary.org/api/books
# Gốc site OL (mặc định https://openlibrary.org) — dùng khi bổ sung description từ edition/work .json
OPEN_LIBRARY_SITE_ORIGIN=https://openlibrary.org
BOOK_LOOKUP_TIMEOUT_SECONDS=8
ENABLE_WORLDCAT_LOOKUP=false
# API key Google Books để tăng quota (tùy chọn)
GOOGLE_BOOKS_API_KEY=

# Groq cloud LLM — free tier, không cần credit. Lấy key tại https://console.groq.com
# Nếu không set, ai-service sẽ fallback về Ollama local.
GROQ_API_KEY=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
GROQ_SUMMARY_MODEL=llama-3.3-70b-versatile

