# Shared environment variables for docker-compose services
# Copy to .env before running Docker stack.

POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=inventory

DB_HOST=db
DB_PORT=5432
DB_USER=user
DB_PASSWORD=password
DB_NAME=inventory
AUTH_DB_NAME=auth_db
INVENTORY_DB_NAME=inventory_db

JWT_SECRET=smartbook_shared_jwt_secret

PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin

# Used by frontend in local runtime
VITE_API_BASE_URL=http://localhost:3000
VITE_AUTH_BASE_URL=http://localhost:3000
VITE_AI_BASE_URL=http://localhost:8000

# Optional: AI summary model used by ai-service
SUMMARY_MODEL=llama3
