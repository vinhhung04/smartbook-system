{
  "name": "smartbook-system",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "dev": "pnpm -r --parallel --filter ./apps/* --filter ./services/* dev",
    "build": "pnpm -r --filter ./apps/* build",
    "lint": "pnpm -r --filter ./apps/* lint",
    "doctor:react": "npx -y react-doctor@latest .",
    "doctor:react:web": "pnpm --dir apps/web run doctor:react",
    "start": "pnpm -r --parallel --filter ./apps/* --filter ./services/* start",
    "dev:web": "pnpm --filter web dev",
    "dev:auth": "pnpm --filter auth-service dev",
    "dev:inventory": "pnpm --filter inventory-service dev",
    "dev:gateway": "pnpm --filter api-gateway dev"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "http-proxy-middleware": "^3.0.5"
  }
}
