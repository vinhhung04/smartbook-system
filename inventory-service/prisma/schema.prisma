generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model authors {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  full_name    String         @unique @db.VarChar(150)
  sort_name    String?        @db.VarChar(150)
  biography    String?
  created_at   DateTime       @default(now()) @db.Timestamptz(6)
  updated_at   DateTime       @default(now()) @db.Timestamptz(6)
  book_authors book_authors[]

  @@index([full_name(ops: raw("gin_trgm_ops"))], map: "idx_authors_full_name_trgm", type: Gin)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model book_authors {
  book_id      String  @db.Uuid
  author_id    String  @db.Uuid
  author_order Int     @default(1)
  authors      authors @relation(fields: [author_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  books        books   @relation(fields: [book_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([book_id, author_id])
}

model book_categories {
  book_id     String     @db.Uuid
  category_id String     @db.Uuid
  books       books      @relation(fields: [book_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  categories  categories @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([book_id, category_id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model book_images {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  book_id       String?        @db.Uuid
  variant_id    String?        @db.Uuid
  image_url     String
  image_type    String         @default("COVER") @db.VarChar(20)
  is_primary    Boolean        @default(false)
  created_at    DateTime       @default(now()) @db.Timestamptz(6)
  books         books?         @relation(fields: [book_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  book_variants book_variants? @relation(fields: [variant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model book_variants {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  book_id              String                 @db.Uuid
  sku                  String                 @unique @db.VarChar(50)
  isbn13               String?                @unique @db.VarChar(20)
  isbn10               String?                @unique @db.VarChar(20)
  internal_barcode     String?                @unique @db.VarChar(50)
  cover_type           String                 @default("PAPERBACK") @db.VarChar(20)
  language_code        String                 @default("vi") @db.VarChar(10)
  publish_year         Int?
  condition_grade      String                 @default("NEW") @db.VarChar(20)
  unit_cost            Decimal                @default(0) @db.Decimal(12, 2)
  list_price           Decimal                @default(0) @db.Decimal(12, 2)
  replacement_cost     Decimal                @default(0) @db.Decimal(12, 2)
  is_borrowable        Boolean                @default(true)
  is_sellable          Boolean                @default(false)
  is_track_by_unit     Boolean                @default(false)
  cover_image_url      String?
  metadata             Json                   @default("{}")
  is_active            Boolean                @default(true)
  created_at           DateTime               @default(now()) @db.Timestamptz(6)
  updated_at           DateTime               @default(now()) @db.Timestamptz(6)
  book_images          book_images[]
  books                books                  @relation(fields: [book_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  goods_receipt_items  goods_receipt_items[]
  inventory_units      inventory_units[]
  outbound_order_items outbound_order_items[]
  purchase_order_items purchase_order_items[]
  stock_alerts         stock_alerts[]
  stock_audit_lines    stock_audit_lines[]
  stock_balances       stock_balances[]
  stock_movements      stock_movements[]
  stock_reservations   stock_reservations[]
  supplier_variants    supplier_variants[]
  transfer_order_items transfer_order_items[]

  @@index([book_id], map: "idx_book_variants_book_id")
  @@index([isbn13], map: "idx_book_variants_isbn13")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model books {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  book_code         String?           @unique @db.VarChar(30)
  title             String            @db.VarChar(255)
  subtitle          String?           @db.VarChar(255)
  description       String?
  publisher_id      String?           @db.Uuid
  edition           String?           @db.VarChar(50)
  published_date    DateTime?         @db.Date
  page_count        Int?
  country_of_origin String?           @db.VarChar(100)
  default_language  String?           @db.VarChar(10)
  is_active         Boolean           @default(true)
  metadata          Json              @default("{}")
  created_at        DateTime          @default(now()) @db.Timestamptz(6)
  updated_at        DateTime          @default(now()) @db.Timestamptz(6)
  book_authors      book_authors[]
  book_categories   book_categories[]
  book_images       book_images[]
  book_variants     book_variants[]
  publishers        publishers?       @relation(fields: [publisher_id], references: [id], onUpdate: NoAction)

  @@index([title(ops: raw("gin_trgm_ops"))], map: "idx_books_title_trgm", type: Gin)
}

model categories {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String            @db.VarChar(120)
  slug             String            @unique @db.VarChar(150)
  parent_id        String?           @db.Uuid
  description      String?
  created_at       DateTime          @default(now()) @db.Timestamptz(6)
  updated_at       DateTime          @default(now()) @db.Timestamptz(6)
  book_categories  book_categories[]
  categories       categories?       @relation("categoriesTocategories", fields: [parent_id], references: [id], onUpdate: NoAction)
  other_categories categories[]      @relation("categoriesTocategories")

  @@unique([parent_id, name])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model goods_receipt_items {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
