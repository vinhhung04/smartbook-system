  variant_id       String         @db.Uuid
  location_id      String?        @db.Uuid
  quantity         Int
  unit_cost        Decimal        @default(0) @db.Decimal(12, 2)
  condition_grade  String         @default("NEW") @db.VarChar(20)
  note             String?
  goods_receipts   goods_receipts @relation(fields: [goods_receipt_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  locations        locations?     @relation(fields: [location_id], references: [id], onUpdate: NoAction)
