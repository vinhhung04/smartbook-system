generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model customers {
  id                 String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_code      String                  @unique @db.VarChar(30)
  full_name          String                  @db.VarChar(150)
  email              String?                 @unique @db.Citext
  phone              String?                 @unique @db.VarChar(30)
  birth_date         DateTime?               @db.Date
  address            String?
  status             String                  @default("ACTIVE") @db.VarChar(20)
  total_fine_balance Decimal                 @default(0) @db.Decimal(12, 2)
  created_at         DateTime                @default(now()) @db.Timestamptz(6)
  updated_at         DateTime                @default(now()) @db.Timestamptz(6)
  account_ledger      account_ledger[]
  payment_methods     payment_methods[]
  customer_memberships customer_memberships[]
  customer_accounts    customer_accounts?
  customer_notifications customer_notifications[]
  auto_payment_settings auto_payment_settings?
  customer_preferences customer_preferences?
  book_reviews       book_reviews[]
  book_wishlists     book_wishlists[]
  availability_alerts availability_alerts[]
  fines              fines[]
  loan_reservations  loan_reservations[]
  loan_transactions  loan_transactions[]

  @@index([status], map: "idx_customers_status")
}

model membership_plans {
  id                       String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                     String                 @unique @db.VarChar(30)
  name                     String                 @db.VarChar(100)
  description              String?
  max_active_loans         Int                    @default(5)
  max_loan_days            Int                    @default(14)
  max_renewal_count        Int                    @default(2)
  reservation_hold_hours   Int                    @default(24)
  fine_per_day             Decimal                @default(0) @db.Decimal(10, 2)
  lost_item_fee_multiplier Decimal                @default(1) @db.Decimal(5, 2)
  is_active                Boolean                @default(true)
  created_at               DateTime               @default(now()) @db.Timestamptz(6)
  updated_at               DateTime               @default(now()) @db.Timestamptz(6)
  customer_memberships     customer_memberships[]
}

model customer_memberships {
  id                        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id               String           @db.Uuid
  plan_id                   String           @db.Uuid
  card_number               String           @unique @db.VarChar(40)
  start_date                DateTime         @default(now()) @db.Date
  end_date                  DateTime?        @db.Date
  status                    String           @default("ACTIVE") @db.VarChar(20)
  max_active_loans_override Int?
  max_loan_days_override    Int?
  note                      String?
  created_at                DateTime         @default(now()) @db.Timestamptz(6)
  updated_at                DateTime         @default(now()) @db.Timestamptz(6)
  customers                 customers        @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  membership_plans          membership_plans @relation(fields: [plan_id], references: [id], onUpdate: NoAction)

  @@index([customer_id], map: "idx_customer_memberships_customer_id")
  @@index([status], map: "idx_customer_memberships_status")
}

model customer_preferences {
  customer_id        String    @id @db.Uuid
  notify_email       Boolean   @default(true)
  notify_sms         Boolean   @default(false)
  notify_in_app      Boolean   @default(true)
  preferred_language String    @default("vi") @db.VarChar(10)
  updated_at         DateTime  @default(now()) @db.Timestamptz(6)
  customers          customers @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model loan_reservations {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reservation_number String    @unique @db.VarChar(40)
  customer_id        String    @db.Uuid
  variant_id         String    @db.Uuid
  inventory_unit_id  String?   @db.Uuid
  warehouse_id       String    @db.Uuid
  pickup_location_id String?   @db.Uuid
  quantity           Int       @default(1)
  source_channel     String    @default("WEB") @db.VarChar(20)
  status             String    @default("PENDING") @db.VarChar(30)
  reserved_at        DateTime  @default(now()) @db.Timestamptz(6)
  expires_at         DateTime  @db.Timestamptz(6)
  notes              String?
  created_by_user_id String?   @db.Uuid
  updated_at         DateTime  @default(now()) @db.Timestamptz(6)
  customers          customers @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  loan_transactions  loan_transactions[]

  @@index([status, expires_at], map: "idx_loan_reservations_status_expires")
}

model loan_transactions {
  id                    String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  loan_number           String            @unique @db.VarChar(40)
  customer_id           String            @db.Uuid
  warehouse_id          String            @db.Uuid
  handled_by_user_id    String            @db.Uuid
  source_reservation_id String?           @db.Uuid
  borrow_date           DateTime          @default(now()) @db.Timestamptz(6)
  due_date              DateTime          @db.Timestamptz(6)
  closed_at             DateTime?         @db.Timestamptz(6)
  status                String            @default("BORROWED") @db.VarChar(20)
  total_items           Int               @default(0)
  notes                 String?
  created_at            DateTime          @default(now()) @db.Timestamptz(6)
  updated_at            DateTime          @default(now()) @db.Timestamptz(6)
  customers             customers         @relation(fields: [customer_id], references: [id], onUpdate: NoAction)
  loan_reservations     loan_reservations? @relation(fields: [source_reservation_id], references: [id], onUpdate: NoAction)
  loan_items            loan_items[]

  @@index([customer_id, status], map: "idx_loan_transactions_customer_id")
  @@index([due_date, status], map: "idx_loan_transactions_due_date")
}

model loan_items {
  id                      String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  loan_id                 String             @db.Uuid
  variant_id              String             @db.Uuid
  inventory_unit_id       String?            @db.Uuid
  item_barcode            String?            @db.VarChar(100)
  due_date                DateTime           @db.Timestamptz(6)
  return_date             DateTime?          @db.Timestamptz(6)
  returned_to_warehouse_id String?           @db.Uuid
  returned_to_location_id String?            @db.Uuid
  item_condition_on_checkout String          @default("GOOD") @db.VarChar(20)
  item_condition_on_return String?           @db.VarChar(20)
  status                  String             @default("BORROWED") @db.VarChar(20)
  fine_amount             Decimal            @default(0) @db.Decimal(10, 2)
  lost_fee_amount         Decimal            @default(0) @db.Decimal(10, 2)
  notes                   String?
  fines                   fines[]
  loan_renewals           loan_renewals[]
  loan_transactions       loan_transactions  @relation(fields: [loan_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([loan_id, status], map: "idx_loan_items_loan_status")
}

model loan_renewals {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  loan_item_id      String    @db.Uuid
  renewed_by_user_id String?  @db.Uuid
  renewed_at        DateTime  @default(now()) @db.Timestamptz(6)
  old_due_date      DateTime  @db.Timestamptz(6)
  new_due_date      DateTime  @db.Timestamptz(6)
  renewal_count     Int
  reason            String?
  loan_items        loan_items @relation(fields: [loan_item_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([loan_item_id], map: "idx_loan_renewals_loan_item_id")
}

model fines {
  id                String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id       String         @db.Uuid
  loan_item_id      String?        @db.Uuid
  fine_type         String         @db.VarChar(20)
  amount            Decimal        @db.Decimal(10, 2)
  waived_amount     Decimal        @default(0) @db.Decimal(10, 2)
  status            String         @default("UNPAID") @db.VarChar(20)
  issued_by_user_id String?        @db.Uuid
  issued_at         DateTime       @default(now()) @db.Timestamptz(6)
  paid_at           DateTime?      @db.Timestamptz(6)
  waived_by_user_id String?        @db.Uuid
  note              String?
  customers         customers      @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  loan_items        loan_items?    @relation(fields: [loan_item_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  fine_payments     fine_payments[]

  @@index([customer_id, status], map: "idx_fines_customer_status")
  @@index([loan_item_id], map: "idx_fines_loan_item_id")
}

model fine_payments {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fine_id               String    @db.Uuid
  payment_method        String    @db.VarChar(20)
  amount                Decimal   @db.Decimal(10, 2)
  transaction_reference String?
  paid_by_user_id       String?   @db.Uuid
  paid_at               DateTime  @default(now()) @db.Timestamptz(6)
  note                  String?
  fines                 fines     @relation(fields: [fine_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([fine_id], map: "idx_fine_payments_fine_id")
}

model customer_notifications {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id   String    @db.Uuid
  channel       String    @db.VarChar(20)
  template_code String?   @db.VarChar(50)
  subject       String?   @db.VarChar(200)
  body          String
  reference_type String?  @db.VarChar(50)
  reference_id  String?   @db.Uuid
  status        String    @default("PENDING") @db.VarChar(20)
  scheduled_at  DateTime  @default(now()) @db.Timestamptz(6)
  sent_at       DateTime? @db.Timestamptz(6)
  read_at       DateTime? @db.Timestamptz(6)
  metadata      Json      @default("{}")
  customers     customers @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([status, scheduled_at], map: "idx_customer_notifications_status")
}

model book_reviews {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id String    @db.Uuid
  book_id     String    @db.Uuid
  rating      Int       @db.SmallInt
  comment     String?
  status      String    @default("VISIBLE") @db.VarChar(20)
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  updated_at  DateTime  @default(now()) @db.Timestamptz(6)
  customers   customers @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([customer_id, book_id], map: "uniq_book_reviews_customer_book")
  @@index([book_id], map: "idx_book_reviews_book_id")
  @@index([customer_id], map: "idx_book_reviews_customer_id")
}

model book_wishlists {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id String   @db.Uuid
  book_id     String   @db.Uuid
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  customers   customers @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([customer_id, book_id], map: "uniq_book_wishlists_customer_book")
  @@index([customer_id], map: "idx_book_wishlists_customer_id")
}

model availability_alerts {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id String    @db.Uuid
  book_id     String    @db.Uuid
  status      String    @default("ACTIVE") @db.VarChar(20)
  notified_at DateTime? @db.Timestamptz(6)
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  customers   customers @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([customer_id, book_id], map: "uniq_availability_alerts_customer_book")
  @@index([book_id, status], map: "idx_availability_alerts_book_status")
}

model borrow_audit_logs {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actor_user_id String?  @db.Uuid
  action_name   String   @db.VarChar(100)
  entity_type   String   @db.VarChar(50)
  entity_id     String?  @db.Uuid
  before_data   Json?
  after_data    Json?
  created_at    DateTime @default(now()) @db.Timestamptz(6)
}

model customer_accounts {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id       String          @unique @db.Uuid
  currency_code     String          @default("VND") @db.VarChar(10)
  status            String          @default("ACTIVE") @db.VarChar(20)
  available_balance Decimal         @default(0) @db.Decimal(12, 2)
  held_balance      Decimal         @default(0) @db.Decimal(12, 2)
  total_credited    Decimal         @default(0) @db.Decimal(12, 2)
  total_debited     Decimal         @default(0) @db.Decimal(12, 2)
  created_at        DateTime        @default(now()) @db.Timestamptz(6)
  updated_at        DateTime        @default(now()) @db.Timestamptz(6)
  customers         customers       @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  account_ledger    account_ledger[]

  @@index([status], map: "idx_customer_accounts_status")
}

model account_ledger {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  account_id        String            @db.Uuid
  customer_id       String            @db.Uuid
  entry_type        String            @db.VarChar(20)
  amount            Decimal           @db.Decimal(12, 2)
  balance_before    Decimal           @db.Decimal(12, 2)
  balance_after     Decimal           @db.Decimal(12, 2)
  reference_type    String?           @db.VarChar(50)
  reference_id      String?           @db.Uuid
  idempotency_key   String?           @db.VarChar(120)
  note              String?
  metadata          Json              @default("{}")
  created_by_user_id String?          @db.Uuid
  created_at        DateTime          @default(now()) @db.Timestamptz(6)
  customer_accounts customer_accounts @relation(fields: [account_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  customers         customers         @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([account_id, created_at], map: "idx_account_ledger_account_created")
  @@index([customer_id, created_at], map: "idx_account_ledger_customer_created")
  @@index([entry_type], map: "idx_account_ledger_entry_type")
  @@unique([customer_id, idempotency_key], map: "uniq_account_ledger_customer_idempotency")
}

model payment_methods {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id         String    @db.Uuid
  method_type         String    @db.VarChar(20)
  provider            String?   @db.VarChar(40)
  provider_reference  String?   @db.VarChar(100)
  masked_account      String?   @db.VarChar(50)
  is_default          Boolean   @default(false)
  status              String    @default("ACTIVE") @db.VarChar(20)
  metadata            Json      @default("{}")
  created_at          DateTime  @default(now()) @db.Timestamptz(6)
  updated_at          DateTime  @default(now()) @db.Timestamptz(6)
  customers           customers @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([customer_id, status], map: "idx_payment_methods_customer_status")
}

model auto_payment_settings {
  customer_id                 String    @id @db.Uuid
  auto_debit_borrow_fee       Boolean   @default(true)
  auto_debit_fines            Boolean   @default(false)
  allow_partial_fine_payment  Boolean   @default(true)
  min_wallet_balance_required Decimal   @default(0) @db.Decimal(12, 2)
  default_payment_method_id   String?   @db.Uuid
  updated_at                  DateTime  @default(now()) @db.Timestamptz(6)
  customers                   customers @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model integration_outbox {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  aggregate_type String   @db.VarChar(100)
  aggregate_id   String?  @db.Uuid
  event_type     String   @db.VarChar(100)
  payload        Json
  headers        Json     @default("{}")
  status         String   @default("PENDING") @db.VarChar(20)
  retry_count    Int      @default(0)
  occurred_at    DateTime @default(now()) @db.Timestamptz(6)
  published_at   DateTime? @db.Timestamptz(6)

  @@index([status, occurred_at], map: "idx_integration_outbox_status_occurred")
}

model integration_inbox {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source_service String   @db.VarChar(50)
  event_id       String   @db.Uuid
  event_type     String   @db.VarChar(100)
  payload        Json
  status         String   @default("RECEIVED") @db.VarChar(20)
  error_message  String?
  received_at    DateTime @default(now()) @db.Timestamptz(6)
  processed_at   DateTime? @db.Timestamptz(6)

  @@unique([source_service, event_id], map: "integration_inbox_source_service_event_id_key")
  @@index([status, received_at], map: "idx_integration_inbox_status_received")
}
